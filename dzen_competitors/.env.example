# Скопируйте в .env. Все поля опциональны — работают значения по умолчанию.

# Браузер
HEADLESS=true
BROWSER_TIMEOUT=60000

# Паузы между запросами (секунды) — анти-троттлинг Дзена
MIN_DELAY=1.0
MAX_DELAY=3.0

# Скролл
MAX_SCROLLS_SEARCH=15
MAX_SCROLLS_CHANNEL=10
SCROLL_IDLE_ROUNDS=3

# Лимиты прогона
MAX_CHANNELS_PER_QUERY=60     # каналов с одного запроса (вкладка "Каналы")
MAX_CHANNELS=100              # всего каналов к детальному обходу
MAX_ARTICLES_PER_CHANNEL=30   # статей с канала (новое + популярное)

# Окно свежести для метрики активности (дней)
WINDOW_DAYS=30

# База
DB_PATH=data/dzen_competitors.sqlite
REPORT_DIR=data
